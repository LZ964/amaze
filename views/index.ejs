
<div style="padding: 20px; max-width: 1200px; margin: 0 auto;">
    <% if (searchTerm) { %>
        <h2 style="font-size: 1.2rem; color: #333;">Résultats pour "<%= searchTerm %>"</h2>
    <% } %>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 20px;">
        <% products.forEach(p => { %>
            <div style="background: white; border: 1px solid #ddd; padding: 15px; display: flex; flex-direction: column; border-radius: 4px;">
                <div style="height: 180px; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                    <img src="<%= p.image %>" style="max-width: 100%; max-height: 100%; object-fit: contain;">
                </div>
                <h4 style="font-size: 14px; height: 40px; overflow: hidden; margin: 0; color: #007185;"><%= p.name %></h4>
                
                <div style="margin: 15px 0;">
                    <a href="<%= p.affiliateUrl %>" target="_blank" style="display: inline-block; background: #ffd814; border: 1px solid #a88734; border-radius: 20px; padding: 10px 20px; text-decoration: none; color: #111; font-size: 13px; font-weight: bold; width: 80%; text-align: center;">
                        Vérifier le prix
                    </a>
                </div>
                <p style="font-size: 11px; color: #565959; margin: 0;">Expédié par Amazon</p>
            </div>
        <% }) %>
    </div>
</div>
