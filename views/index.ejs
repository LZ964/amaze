
<div style="padding: 20px; max-width: 1200px; margin: 0 auto;">
    <% if (searchTerm) { %>
        <h2 style="font-size: 20px; margin-bottom: 20px; color: #565959;">
            Résultats pour <span style="color: #c45500;">"<%= searchTerm %>"</span>
        </h2>
    <% } else { %>
        <h2 style="font-size: 20px; margin-bottom: 20px;">Suggestions du moment</h2>
    <% } %>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 15px;">
        <% products.forEach(p => { %>
            <div style="background: white; padding: 15px; border: 1px solid #e7e7e7; border-radius: 8px; display: flex; flex-direction: column; transition: box-shadow 0.3s;">
                <div style="height: 200px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; background: #f8f8f8; border-radius: 4px;">
                    <img src="<%= p.image %>" alt="<%= p.name %>" style="max-width: 100%; max-height: 100%; object-fit: contain;">
                </div>
                <h4 style="font-size: 14px; line-height: 1.4em; height: 2.8em; overflow: hidden; margin: 0; color: #0f1111;">
                    <%= p.name %>
                </h4>
                <div style="margin: 10px 0;">
                    <span style="font-size: 12px; vertical-align: top; margin-top: 4px; display: inline-block;">$</span>
                    <span style="font-size: 24px; font-weight: bold;"><%= Math.floor(p.price) %></span>
                    <span style="font-size: 12px; vertical-align: top; margin-top: 4px; display: inline-block;"><%= (p.price % 1).toFixed(2).substring(2) %></span>
                </div>
                <a href="<%= p.affiliateUrl %>" target="_blank" style="margin-top: auto; background: #ffd814; border: 1px solid #fcd200; border-radius: 20px; padding: 8px; text-align: center; text-decoration: none; color: #0f1111; font-size: 13px; font-weight: 500; box-shadow: 0 2px 5px rgba(213,217,217,.5);">
                    Voir l'offre sur Amazon
                </a>
            </div>
        <% }) %>
    </div>
</div>
