<!DOCTYPE html><html><head><title><%- title %></title>
<style>
    body{margin:0;font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;background:#eaeded;color:#0f1111;}
    header{background:#131921;padding:10px 20px;display:flex;align-items:center;position:sticky;top:0;z-index:1000;}
    .logo{color:white;font-weight:bold;text-decoration:none;font-size:24px;margin-right:20px;}
    .logo span{color:#ff9900;}
    form{flex:1;display:flex;max-width:800px;margin:0 auto;}
    input{width:100%;padding:12px 15px;border:none;border-radius:4px 0 0 4px;outline:none;font-size:16px;}
    button{background:#febd69;border:none;padding:0 20px;border-radius:0 4px 4px 0;cursor:pointer;font-size:20px;transition: background 0.2s;}
    button:hover{background:#f3a847;}
</style>
</head><body>
    <header>
        <a href="/" class="logo">amazon<span>clone</span></a>
        <form action="/" method="GET">
            <input type="text" name="q" placeholder="Rechercher sur AmazonClone..." value="<%= searchTerm %>" autocomplete="off">
            <button type="submit">🔍</button>
        </form>
    </header>
    <%- body %>
</body></html>