<!DOCTYPE html><html><head><title><%- title %></title>
<style>
    body{margin:0; font-family: 'Arial', sans-serif; background: #f3f3f3; color: #111;}
    header{background: #131921; padding: 10px 20px; display: flex; align-items: center;}
    .logo{color: white; font-weight: bold; text-decoration: none; font-size: 22px; margin-right: 20px;}
    .logo span{color: #ff9900;}
    form{flex: 1; display: flex;}
    input{width: 100%; padding: 10px; border: none; border-radius: 4px 0 0 4px; outline: none;}
    button{background: #febd69; border: none; padding: 10px 20px; border-radius: 0 4px 4px 0; cursor: pointer;}
    footer{background: #232f3e; color: white; padding: 30px 20px; text-align: center; margin-top: 50px; font-size: 13px; line-height: 1.6;}
</style>
</head><body>
    <header>
        <a href="/" class="logo">amazon<span>clone</span></a>
        <form action="/" method="GET">
            <input type="text" name="q" placeholder="Rechercher des produits..." value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>">
            <button type="submit">🔍</button>
        </form>
    </header>

    <%- body %>

    <footer>
        <p>En tant que Partenaire Amazon, je réalise un bénéfice sur les achats remplissant les conditions requises.</p>
        <p>© 2026 AmazonClone - Tous droits réservés.</p>
    </footer>
</body></html>