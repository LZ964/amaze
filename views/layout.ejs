<!DOCTYPE html><html><head><title><%- title %></title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
    body{margin:0; font-family: 'Segoe UI', Arial, sans-serif; background: #eaeded; color: #0f1111;}
    header{background: #131921; padding: 10px 20px; display: flex; align-items: center; position: sticky; top: 0; z-index: 100;}
    .logo{color: white; font-weight: bold; text-decoration: none; font-size: 24px; margin-right: 20px;}
    .logo span{color: #ff9900;}
    form{flex: 1; display: flex; max-width: 800px;}
    input{width: 100%; padding: 10px 15px; border: none; border-radius: 4px 0 0 4px; outline: none; font-size: 15px;}
    button{background: #febd69; border: none; padding: 0 20px; border-radius: 0 4px 4px 0; cursor: pointer; font-size: 18px;}
    footer{background: #232f3e; color: white; padding: 40px 20px; text-align: center; margin-top: 50px; font-size: 13px;}
</style>
</head><body>
    <header>
        <a href="/" class="logo">amazon<span>clone</span></a>
        <form action="/" method="GET">
            <input type="text" name="q" placeholder="Rechercher des produits..." value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>" required>
            <button type="submit">🔍</button>
        </form>
    </header>
    <%- body %>
    <footer>
        <p>En tant que Partenaire Amazon, je réalise un bénéfice sur les achats remplissant les conditions requises.</p>
        <p>© 2026 AmazonClone. Site de démonstration conforme aux règles Amazon Associates.</p>
    </footer>
</body></html>