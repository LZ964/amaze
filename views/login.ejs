
        <div style="max-width: 350px; margin: 40px auto; background: white; padding: 25px; border: 1px solid #ddd; border-radius: 8px;">
            <h1 style="font-size: 28px; margin-bottom: 20px; font-weight: 400;">S'identifier</h1>
            <% if (error) { %><p style="color:#c40000; font-size: 13px;"><%= error %></p><% } %>
            <form method="POST">
                <label style="font-size: 13px; font-weight: bold;">Adresse courriel</label><br>
                <input type="email" name="email" required style="width: 100%; padding: 7px; margin: 5px 0 15px 0; border: 1px solid #a6a6a6; border-radius: 3px;"><br>
                <label style="font-size: 13px; font-weight: bold;">Mot de passe</label><br>
                <input type="password" name="password" required style="width: 100%; padding: 7px; margin: 5px 0 20px 0; border: 1px solid #a6a6a6; border-radius: 3px;"><br>
                <button type="submit" class="btn-amazon" style="width: 100%; padding: 10px;">Continuer</button>
            </form>
            <p style="font-size: 12px; color: #555; margin-top: 20px;">En continuant, vous acceptez les conditions d'utilisation d'AmazonClone.</p>
        </div>
    